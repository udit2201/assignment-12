CUSTOM EXCEPTION
#include <iostream>
using namespace std;

class MyException
{
public:
    void message()
    {
        cout << "Custom Exception: Number cannot be negative!" << endl;
    }
};

int main()
{
    int num;

    cout << "Enter a number: ";
    cin >> num;

    try
    {
        if (num < 0)
            throw MyException();

        cout << "You entered: " << num << endl;
    }
    catch (MyException e)
    {
        e.message();
    }

    return 0;
}
OUTPUT
Enter a number: 10
You entered: 10
