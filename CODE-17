HIERARCHICAL INHERITENCE
#include <iostream>
using namespace std;

class Animal
{
public:
    void eat()
    {
        cout << "Animal is eating." << endl;
    }
};

class Dog : public Animal
{
public:
    void bark()
    {
        cout << "Dog is barking." << endl;
    }
};

class Cat : public Animal
{
public:
    void meow()
    {
        cout << "Cat is meowing." << endl;
    }
};

int main()
{
    Dog d;
    Cat c;

    d.eat();
    d.bark();

    c.eat();
    c.meow();

    return 0;
}
OUTPUT
Animal is eating.
Dog is barking.
Animal is eating.
Cat is meowing.
